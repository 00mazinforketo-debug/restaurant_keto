generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum Locale {
  ku
  ar
  fa
  en
  tr
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

model User {
  id              String             @id @default(cuid())
  displayName     String
  role            UserRole
  pinHash         String
  pinLookup       String             @unique
  preferredLocale Locale             @default(ku)
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  sessions        Session[]
  orders          Order[]
  activityLogs    ActivityLog[]      @relation("ActorLogs")
  statusEvents    OrderStatusEvent[] @relation("StatusActor")
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  rememberMe       Boolean  @default(false)
  expiresAt        DateTime
  lastActiveAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  revokedAt        DateTime?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  nameKu    String
  nameAr    String?
  nameFa    String?
  nameEn    String?
  nameTr    String?
  icon      String?
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  menuItems MenuItem[]
}

model MenuItem {
  id            String                @id @default(cuid())
  slug          String                @unique
  categoryId    String
  basePrice     Decimal               @db.Decimal(10, 2)
  imageUrl      String?
  imagePublicId String?
  isAvailable   Boolean               @default(true)
  sortOrder     Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  category      Category              @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  translations  MenuItemTranslation[]
  orderItems    OrderItem[]

  @@index([categoryId])
}

model MenuItemTranslation {
  id          String   @id @default(cuid())
  menuItemId  String
  locale      Locale
  name        String
  description String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, locale])
}

model TableRef {
  id        String   @id @default(cuid())
  label     String   @unique
  qrToken   String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id                 String             @id @default(cuid())
  orderCode          String             @unique
  userId             String
  customerNameKu     String
  customerPhone      String
  customerAddressKu  String
  notesKu            String?
  tableRefId         String?
  tableLabelSnapshot String?
  status             OrderStatus        @default(PENDING)
  localeAtCheckout   Locale             @default(ku)
  totalPrice         Decimal            @db.Decimal(10, 2)
  placedAt           DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  items              OrderItem[]
  statusEvents       OrderStatusEvent[]
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tableRef           TableRef?          @relation(fields: [tableRefId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([placedAt])
  @@index([customerPhone])
}

model OrderItem {
  id                     String   @id @default(cuid())
  orderId                String
  menuItemId             String
  quantity               Int
  unitPrice              Decimal  @db.Decimal(10, 2)
  totalPrice             Decimal  @db.Decimal(10, 2)
  nameKuSnapshot         String
  categoryNameKuSnapshot String
  order                  Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem               MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model OrderStatusEvent {
  id              String      @id @default(cuid())
  orderId         String
  status          OrderStatus
  note            String?
  changedByUserId String?
  createdAt       DateTime    @default(now())
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByUser   User?       @relation("StatusActor", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model ActivityLog {
  id                String    @id @default(cuid())
  actorUserId       String?
  actorNameSnapshot String
  actorRole         UserRole
  action            String
  entityType        String
  entityId          String?
  metadata          Json?
  createdAt         DateTime  @default(now())
  actor             User?     @relation("ActorLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model DailyMetric {
  id              String   @id @default(cuid())
  date            DateTime @unique @db.Date
  totalOrders     Int      @default(0)
  activeOrders    Int      @default(0)
  deliveredOrders Int      @default(0)
  cancelledOrders Int      @default(0)
  revenue         Decimal  @default(0) @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
